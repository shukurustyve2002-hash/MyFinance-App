{
  "entities": {
    "Transaction": {
      "title": "Transaction",
      "description": "Une transaction financière effectuée par l'utilisateur.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "date": { "type": "string" },
        "amount": { "type": "number" },
        "type": { "type": "string", "enum": ["receive", "send", "payment", "save"] },
        "description": { "type": "string" },
        "category": { "type": "string" },
        "userId": { "type": "string" }
      },
      "required": ["id", "date", "amount", "type", "description", "userId"]
    },
    "UserProfile": {
      "title": "User Profile",
      "description": "Données de profil et de score de l'utilisateur.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "displayName": { "type": "string" },
        "email": { "type": "string" },
        "trustScore": { "type": "number" },
        "rating": { "type": "string" }
      },
      "required": ["uid", "email"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": "UserProfile",
      "description": "Profils utilisateurs."
    },
    "users/{userId}/transactions/{transactionId}": {
      "schema": "Transaction",
      "description": "Sous-collection des transactions pour chaque utilisateur."
    }
  }
}
